# Site URL (used for metadata)
NEXT_PUBLIC_SITE_URL=https://aethex.org

# Discord Server ID (for the widget - enable Server Widget in Discord settings)
NEXT_PUBLIC_DISCORD_SERVER_ID=YOUR_DISCORD_SERVER_ID

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Open Collective (optional - for displaying backer info)
# OPEN_COLLECTIVE_API_KEY=your_api_key
